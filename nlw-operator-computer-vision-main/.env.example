# ============================================
# NLW Operator Computer Vision - Environment Variables
# ============================================
# Copie este arquivo para .env e configure os valores
# cp .env.example .env
# ============================================

# ============================================
# GOOGLE GEMINI API (OBRIGATÓRIO - recog_system)
# ============================================
# Chave da API do Google Gemini
# Obtain at: https://aistudio.google.com/app/apikey
# Necessário para modelos Gemini Vision
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# GOOGLE CLOUD VISION API (OPCIONAL)
# ============================================
# Chave da API do Google Cloud Vision
# Obtain at: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLOUD_VISION_API_KEY=your-cloud-vision-key-here

# ============================================
# HUGGING FACE (OPCIONAL)
# ============================================
# Token de acesso Hugging Face (para modelos privados)
# Obtain at: https://huggingface.co/settings/tokens
# HF_TOKEN=your-huggingface-token-here

# ============================================
# CONFIGURAÇÕES DE DESENVOLVIMENTO (OPCIONAL)
# ============================================
# Ambiente de execução
# NODE_ENV=development

# Porta do servidor (padrão: 8000)
# PORT=8000
